{
  "name": "urfave-cli",
  "root": "${BASE_DIR}/edr-bench-urfave-cli",
  "scope_dir": ".",
  "scenarios": {
    "understand_api": {
      "type": "read_signatures",
      "file": "command.go",
      "spec": "command.go:Command"
    },
    "read_symbol": {
      "type": "read_symbol",
      "file": "help.go",
      "spec": "help.go:ShowCommandHelp"
    },
    "find_refs": {
      "type": "refs",
      "pattern": "ShowCommandHelp",
      "grep_root": ".",
      "args": ["help.go", "ShowCommandHelp"]
    },
    "search_context": {
      "type": "search",
      "pattern": "shellCompletion",
      "search_root": ".",
      "budget": 500
    },
    "orient_map": {
      "type": "map",
      "dir": ".",
      "budget": 500,
      "globs": ["*.go"],
      "read_files": [
        "command.go",
        "app.go",
        "help.go",
        "flag.go"
      ]
    },
    "edit_function": {
      "type": "edit",
      "file": "command.go",
      "old_text": "// HasName returns true if Command.Name matches given name",
      "new_text": "// HasName reports whether Command.Name matches the given name"
    },
    "add_method": {
      "type": "write_inside",
      "file": "command.go",
      "inside": "Command",
      "content": "func (cmd *Command) HasSubcommands() bool {\n\treturn len(cmd.Subcommands) > 0\n}\n"
    },
    "multi_file_read": {
      "type": "multi_read",
      "budget": 500,
      "files": [
        "command.go",
        "app.go",
        "context.go"
      ]
    },
    "explore_symbol": {
      "type": "explore",
      "pattern": "ShowCommandHelp",
      "grep_root": ".",
      "args": ["help.go", "ShowCommandHelp"],
      "native_read_files": [
        "help.go",
        "app.go",
        "command.go"
      ]
    }
  }
}
