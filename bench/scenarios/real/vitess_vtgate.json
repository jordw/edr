{
  "name": "vitess-vtgate",
  "root": "${BASE_DIR}/edr-bench-vitess/go/vt/vtgate",
  "scope_dir": ".",
  "scenarios": {
    "understand_api": {
      "type": "read_signatures",
      "file": "executor.go",
      "spec": "executor.go:Executor"
    },
    "read_symbol": {
      "type": "read_symbol",
      "file": "executor.go",
      "spec": "executor.go:fetchOrCreatePlan"
    },
    "find_refs": {
      "type": "refs",
      "pattern": "fetchOrCreatePlan",
      "grep_root": ".",
      "args": ["executor.go", "fetchOrCreatePlan"]
    },
    "search_context": {
      "type": "search",
      "pattern": "rollback",
      "search_root": ".",
      "budget": 500
    },
    "orient_map": {
      "type": "map",
      "dir": ".",
      "budget": 500,
      "globs": ["*.go"],
      "read_files": [
        "executor.go",
        "plan_execute.go",
        "planbuilder/builder.go",
        "planbuilder/planner.go"
      ]
    },
    "edit_function": {
      "type": "edit",
      "file": "plan_execute.go",
      "old_text": "// 5: Log and add statistics",
      "new_text": "// 5: Record and add statistics"
    },
    "add_method": {
      "type": "write_inside",
      "file": "executor.go",
      "inside": "Executor",
      "content": "func (e *Executor) HasPlanCache() bool {\n\treturn e.plans != nil\n}\n"
    },
    "multi_file_read": {
      "type": "multi_read",
      "budget": 500,
      "files": [
        "executor.go",
        "plan_execute.go",
        "planbuilder/builder.go"
      ]
    },
    "explore_symbol": {
      "type": "explore",
      "pattern": "fetchOrCreatePlan",
      "grep_root": ".",
      "args": ["executor.go", "fetchOrCreatePlan"],
      "native_read_files": [
        "executor.go",
        "plan_execute.go"
      ]
    }
  }
}
