{
  "name": "django",
  "root": "${BASE_DIR}/edr-bench-django/django",
  "scope_dir": ".",
  "scenarios": {
    "understand_api": {
      "type": "read_signatures",
      "file": "db/models/query.py",
      "spec": "db/models/query.py:QuerySet"
    },
    "read_symbol": {
      "type": "read_symbol",
      "file": "db/models/sql/compiler.py",
      "spec": "db/models/sql/compiler.py:as_sql"
    },
    "find_refs": {
      "type": "refs",
      "pattern": "get_fields",
      "grep_root": "db",
      "args": ["db/models/options.py", "get_fields"]
    },
    "search_context": {
      "type": "search",
      "pattern": "queryset",
      "search_root": "db",
      "budget": 500
    },
    "orient_map": {
      "type": "map",
      "dir": "db/models",
      "budget": 500,
      "globs": ["*.py"],
      "read_files": [
        "db/models/base.py",
        "db/models/query.py",
        "db/models/fields/__init__.py",
        "db/models/manager.py"
      ]
    },
    "edit_function": {
      "type": "edit",
      "file": "db/models/query.py",
      "old_text": "Return a new QuerySet instance with the args ANDed to the existing",
      "new_text": "Return a new QuerySet instance with the args ANDed to the current"
    },
    "add_method": {
      "type": "write_inside",
      "file": "db/models/query.py",
      "inside": "QuerySet",
      "content": "    def is_empty(self) -> bool:\n        \"\"\"Return True if the queryset has no results.\"\"\"\n        return not self.exists()\n"
    },
    "multi_file_read": {
      "type": "multi_read",
      "budget": 500,
      "files": [
        "db/models/base.py",
        "db/models/query.py",
        "db/models/sql/compiler.py"
      ]
    },
    "explore_symbol": {
      "type": "explore",
      "pattern": "get_fields",
      "grep_root": "db",
      "args": ["db/models/options.py", "get_fields"],
      "native_read_files": [
        "db/models/options.py",
        "db/models/base.py",
        "db/models/sql/compiler.py"
      ]
    }
  }
}
